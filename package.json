    "remove:prod": "sls remove --stage prod",
    "remove:stg": "sls remove --stage stg"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1088.0",
    "@slack/bolt": "^5.0.0",
    "openai": "^6.47.0"
  },
  "devDependencies": {
    "@slack/types": "^3.0.0",
    "@slack/web-api": "^8.0.0",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^24.0.0",
    "serverless": "^4.39.0",
    "typescript": "^5.9.3"
  }
}
